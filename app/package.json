{
  "name": "crystalis-autotracker",
  "productName": "Crystalis Autotracker",
  "version": "0.1.0",
  "description": "Standalone auto-tracker and randomizer launcher for Crystalis (NES) via Mesen 2",
  "main": "./out/main/index.js",
  "author": "Michael Rowe",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "crystalis-randomizer": "2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^4.0.0",
    "json5": "^2.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
